            wire#w1
            Coil( "InputValues_DB".InputsDigital.EmergencyStop )
        END_RUNG
        RUNG wire#powerrail
            Contact( "Simulation_DB".DigitalInputs.EmergencyStop )
            Contact( "Simulation_DB".Simulation )
        END_RUNG wire#w1
    END_NETWORK
