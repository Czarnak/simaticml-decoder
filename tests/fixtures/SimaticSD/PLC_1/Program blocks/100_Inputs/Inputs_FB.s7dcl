        {
            S7_Access := "ReadOnly := External";
            S7_Visibility := "Hidden := External"
        }
        ResetEdge : Bool;
        {
            S7_Access := "ReadOnly := External";
            S7_Setpoint := "False";
            S7_Visibility := "Hidden := External"
        }
        TankLevel : Array[1..2] of _.AnalogInput;
    END_VAR

    {
        S7_Language := "LAD";
        S7_NetworkTitle := "MLC_4En"
    }
    NETWORK
        RUNG wire#powerrail
        END_RUNG
    END_NETWORK
    {
        S7_Language := "LAD";
        S7_NetworkTitle := "MLC_35C"
    }
    NETWORK
        RUNG wire#powerrail
            Contact( "DI_EmergencyStop" )
