TYPE
    AnalogInputSettings : STRUCT
        Scaling : STRUCT
            { S7_MLC := "MLC_aC" }
            "Type" : Bool := TRUE;
            regMin : Int := 0;
            regMax : Int := 27648;
            valueMin : Real;
            valueMax : Real;
            Multiplier : Real;
        END_STRUCT;
        Limits : STRUCT
            regMin : Int := -500;
            regMax : Int := 30000;
            regAlarmDelay : Time := T#1s;
        END_STRUCT;
    END_STRUCT;
END_TYPE
